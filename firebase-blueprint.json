{
  "entities": {
    "users": {
      "title": "User",
      "description": "Dashboard administrators and managers",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager"] }
      },
      "required": ["uid", "email"]
    },
    "employees": {
      "title": "Employee",
      "description": "Monitored employee records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "department": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "idle", "offline"] },
        "lastSeen": { "type": "string", "format": "date-time" },
        "currentApp": { "type": "string" }
      },
      "required": ["id", "name", "email"]
    },
    "activity_logs": {
      "title": "Activity Log",
      "description": "Individual activity events from agents",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["app_switch", "idle_start", "idle_end", "heartbeat"] },
        "details": {
          "type": "object",
          "properties": {
            "appName": { "type": "string" },
            "windowTitle": { "type": "string" },
            "duration": { "type": "number" }
          }
        }
      },
      "required": ["employeeId", "timestamp", "type"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "users",
      "description": "Admin user profiles"
    },
    "/employees/{employeeId}": {
      "schema": "employees",
      "description": "Employee monitoring data"
    },
    "/activity_logs/{logId}": {
      "schema": "activity_logs",
      "description": "Raw activity stream"
    }
  }
}
